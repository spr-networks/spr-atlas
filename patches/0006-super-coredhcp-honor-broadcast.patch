From: SPR Networks <support@supernetworks.org>
Subject: [PATCH] dhcp: honor the DHCPv4 broadcast flag

Pin SPR's CoreDHCP source and apply a small protocol fix during its image
build. A client with no configured address that sets the DHCP broadcast flag
must receive OFFER/ACK at 255.255.255.255. Sending the reply to yiaddr before
the client owns it works with raw-packet clients but is invisible to normal
UDP DHCP clients, including libkrun's embedded guest configurator.
---
 dhcp/Dockerfile                                     | 12 ++++++++++--
 dhcp/patches/0001-honor-dhcp-broadcast-flag.patch | 29 +++++++++++++++++++++++
 2 files changed, 39 insertions(+), 2 deletions(-)

diff --git a/dhcp/Dockerfile b/dhcp/Dockerfile
--- a/dhcp/Dockerfile
+++ b/dhcp/Dockerfile
@@ -11,10 +11,18 @@ RUN wget https://dl.google.com/go/go1.24.2.linux-$TARGETARCH.tar.gz
 RUN rm -rf /usr/local/go && tar -C /usr/local -xzf go1.24.2.linux-$TARGETARCH.tar.gz
 ENV PATH="/usr/local/go/bin:$PATH"
 
-# Build CoreDHCP
+# Build the pinned SPR CoreDHCP revision with the DHCP broadcast fix.
 ARG CACHEBUST=1
-RUN git clone https://github.com/spr-networks/coredhcp
+ARG COREDHCP_COMMIT=7fc806d5cb53eb17df6cae022c3bde9fe8f5946e
+RUN git init coredhcp && \
+    git -C coredhcp remote add origin https://github.com/spr-networks/coredhcp && \
+    git -C coredhcp fetch --depth 1 origin "$COREDHCP_COMMIT" && \
+    git -C coredhcp checkout --detach "$COREDHCP_COMMIT" && \
+    test "$(git -C coredhcp rev-parse HEAD)" = "$COREDHCP_COMMIT"
 WORKDIR /code/coredhcp
+COPY patches/0001-honor-dhcp-broadcast-flag.patch /tmp/coredhcp-patches/
+RUN git apply --check /tmp/coredhcp-patches/0001-honor-dhcp-broadcast-flag.patch && \
+    git apply /tmp/coredhcp-patches/0001-honor-dhcp-broadcast-flag.patch
 ARG USE_TMPFS=true
 RUN --mount=type=tmpfs,target=/tmpfs \
     [ "$USE_TMPFS" = "true" ] && ln -s /tmpfs /root/go; \
diff --git a/dhcp/patches/0001-honor-dhcp-broadcast-flag.patch b/dhcp/patches/0001-honor-dhcp-broadcast-flag.patch
new file mode 100644
--- /dev/null
+++ b/dhcp/patches/0001-honor-dhcp-broadcast-flag.patch
@@ -0,0 +1,29 @@
+From: SPR Networks <support@supernetworks.org>
+Subject: [PATCH] server: honor the DHCPv4 broadcast flag
+
+RFC 2131 clients that set the broadcast flag may not yet be able to receive
+an IP unicast addressed to yiaddr. Send NAK and requested broadcast replies
+to the IPv4 broadcast address on the receiving interface.
+---
+ server/handle.go | 6 ++----
+ 1 file changed, 2 insertions(+), 4 deletions(-)
+
+diff --git a/server/handle.go b/server/handle.go
+--- a/server/handle.go
++++ b/server/handle.go
+@@ -153,13 +153,11 @@ func (l *listener4) HandleMsg4(buf []byte, oob *ipv4.ControlMessage, _peer net.A
+ 			// TODO: make RFC8357 compliant
+ 			peer = &net.UDPAddr{IP: req.GatewayIPAddr, Port: dhcpv4.ServerPort}
+ 		} else if resp.MessageType() == dhcpv4.MessageTypeNak {
+-//			peer = &net.UDPAddr{IP: net.IPv4bcast, Port: dhcpv4.ClientPort}
+-			peer = &net.UDPAddr{IP: resp.YourIPAddr, Port: dhcpv4.ClientPort}
++			peer = &net.UDPAddr{IP: net.IPv4bcast, Port: dhcpv4.ClientPort}
+ 		} else if !req.ClientIPAddr.IsUnspecified() {
+ 			peer = &net.UDPAddr{IP: req.ClientIPAddr, Port: dhcpv4.ClientPort}
+ 		} else if req.IsBroadcast() {
+-			//peer = &net.UDPAddr{IP: net.IPv4bcast, Port: dhcpv4.ClientPort}
+-			peer = &net.UDPAddr{IP: resp.YourIPAddr, Port: dhcpv4.ClientPort}
++			peer = &net.UDPAddr{IP: net.IPv4bcast, Port: dhcpv4.ClientPort}
+ 		} else {
+ 			//sends a layer2 frame so that we can define the destination MAC address
+ 			peer = &net.UDPAddr{IP: resp.YourIPAddr, Port: dhcpv4.ClientPort}
-- 
