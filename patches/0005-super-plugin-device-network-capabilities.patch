From: SPR Networks <support@supernetworks.org>
Subject: [PATCH] plugins: support DHCP-backed device network capabilities

Allow a plugin to declare a stable device MAC in addition to its interface.
The API authorizes that exact interface/MAC pair for CoreDHCP and seeds the
normal SPR device record with the requested policies. This keeps virtual
machines on the same device, routing, DNS, and firewall path as physical SPR
clients instead of treating the VMM process as a container source IP.
---
 api/code/firewall.go |   2 ++
 api/code/plugins.go  | 108 ++++++++++++++++++++++++++++++++++++++++++++
 2 files changed, 110 insertions(+)

diff --git a/api/code/firewall.go b/api/code/firewall.go
--- a/api/code/firewall.go
+++ b/api/code/firewall.go
@@ -3303,7 +3303,9 @@ func dynamicRouteLoop() {
 					// devices without making them general SPR downlinks.
 					recentIface, hasRecentDHCP := recentDHCPIfaces[ident]
+					_, recentIfaceErr := net.InterfaceByName(new_iface)
 					isAuthorizedDHCPLink := hasRecentDHCP &&
 						recentIface == new_iface &&
+						recentIfaceErr == nil &&
 						isValidIface(new_iface)
 
 					// If it's not a downlink, recent DHCP link, wg0, or a wlan
diff --git a/api/code/plugins.go b/api/code/plugins.go
--- a/api/code/plugins.go
+++ b/api/code/plugins.go
@@ -36,6 +36,7 @@ var CustomComposeAllowPath = TEST_PREFIX + "/configs/base/custom_compose_paths.
 
 type NetworkCapabilities struct {
 	Interface string
+	DeviceMAC string
 	Policies  []string
 	Groups    []string
 }
@@ -68,6 +69,7 @@ func (p PluginConfig) MatchesData(q PluginConfig) bool {
 		p.InstallTokenPath == q.InstallTokenPath &&
 		slices.Compare(p.ScopedPaths, q.ScopedPaths) == 0 &&
 		p.NetworkCapabilities.Interface == q.NetworkCapabilities.Interface &&
+		p.NetworkCapabilities.DeviceMAC == q.NetworkCapabilities.DeviceMAC &&
 		slices.Compare(p.NetworkCapabilities.Policies, q.NetworkCapabilities.Policies) == 0 &&
 		slices.Compare(p.NetworkCapabilities.Groups, q.NetworkCapabilities.Groups) == 0
 }
@@ -768,6 +770,87 @@ func startExtension(composeFilePath string) bool {
 	}
 
 	return true
+}
+
+func pluginDeviceMAC(plugin PluginConfig) (string, error) {
+	mac := trimLower(plugin.NetworkCapabilities.DeviceMAC)
+	if !isValidMAC(mac) {
+		return "", fmt.Errorf("invalid device MAC for plugin %s", plugin.Name)
+	}
+
+	hw, err := net.ParseMAC(mac)
+	if err != nil || len(hw) != 6 || hw[0]&1 != 0 {
+		return "", fmt.Errorf("device MAC for plugin %s must be a six-octet unicast address", plugin.Name)
+	}
+
+	return mac, nil
+}
+
+func applyPluginDeviceNetworkCapabilities(plugin PluginConfig) error {
+	if !isValidIface(plugin.NetworkCapabilities.Interface) {
+		return fmt.Errorf("invalid device interface for plugin %s", plugin.Name)
+	}
+
+	mac, err := pluginDeviceMAC(plugin)
+	if err != nil {
+		return err
+	}
+
+	for _, policy := range plugin.NetworkCapabilities.Policies {
+		if !slices.Contains(ValidPolicyStrings, policy) {
+			return fmt.Errorf("invalid device policy %q for plugin %s", policy, plugin.Name)
+		}
+	}
+
+	// Authorize only this interface/MAC pair for DHCP. The VM is then handled
+	// by CoreDHCP and the normal per-device route and firewall policy path.
+	FWmtx.Lock()
+	err = GetElementFromMapComplex(
+		"inet", "filter", "dhcp_access",
+		[]string{plugin.NetworkCapabilities.Interface, mac},
+	)
+	if err != nil {
+		err = AddElementToMapComplex(
+			"inet", "filter", "dhcp_access",
+			[]string{plugin.NetworkCapabilities.Interface, mac},
+			"accept",
+		)
+	}
+	FWmtx.Unlock()
+	if err != nil {
+		return fmt.Errorf("authorize DHCP for plugin %s: %w", plugin.Name, err)
+	}
+
+	Groupsmtx.Lock()
+	defer Groupsmtx.Unlock()
+	Devicesmtx.Lock()
+	defer Devicesmtx.Unlock()
+
+	devices := getDevicesJson()
+	dev, exists := devices[mac]
+	if !exists {
+		dev = DeviceEntry{
+			Name:       plugin.Name,
+			MAC:        mac,
+			DeviceTags: []string{},
+		}
+	}
+	if dev.Name == "" {
+		dev.Name = plugin.Name
+	}
+	dev.Policies = normalizeStringSlice(plugin.NetworkCapabilities.Policies)
+	dev.Groups = normalizeStringSlice(plugin.NetworkCapabilities.Groups)
+	addGroupsIfMissing(getGroupsJson(), dev.Groups)
+	devices[mac] = dev
+	saveDevicesJson(devices)
+
+	if exists {
+		SprbusPublish("device:update", scrubDevice(dev))
+	} else {
+		SprbusPublish("device:save", scrubDevice(dev))
+	}
+
+	return nil
 }
 
 func applyPluginNetworkCapabilities(plugin PluginConfig) error {
@@ -776,6 +859,10 @@ func applyPluginNetworkCapabilities(plugin PluginConfig) error {
 		return nil
 	}
 
+	if plugin.NetworkCapabilities.DeviceMAC != "" {
+		return applyPluginDeviceNetworkCapabilities(plugin)
+	}
+
 	// Get container IP for this plugin
 	containerIP, err := getPluginContainerIP(plugin.NetworkCapabilities.Interface)
 	if err != nil {
@@ -815,6 +902,27 @@ func removePluginNetworkCapabilities(plugin PluginConfig) error {
 	// Only remove if NetworkCapabilities are defined
 	if plugin.NetworkCapabilities.Interface == "" || len(plugin.NetworkCapabilities.Policies) == 0 {
 		return nil
+	}
+
+	if plugin.NetworkCapabilities.DeviceMAC != "" {
+		mac, err := pluginDeviceMAC(plugin)
+		if err != nil {
+			return err
+		}
+
+		FWmtx.Lock()
+		defer FWmtx.Unlock()
+		delete(RecentDHCPIface, mac)
+		if GetElementFromMapComplex(
+			"inet", "filter", "dhcp_access",
+			[]string{plugin.NetworkCapabilities.Interface, mac},
+		) != nil {
+			return nil
+		}
+		return DeleteElementFromMapComplex(
+			"inet", "filter", "dhcp_access",
+			[]string{plugin.NetworkCapabilities.Interface, mac},
+		)
 	}
 
 	// We need to get the actual rule to delete it properly
-- 
